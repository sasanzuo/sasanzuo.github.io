/* pages/index/index.wxss */

/* 全局背景 */
page {
  background-color: #FAFAF9; /* 温暖的米灰色 */
  color: #1C1917;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ================================= */
/* 1. Header 区域 (粘性定位) */
/* ================================= */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  
  background-color: rgba(250, 250, 249, 0.98);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid rgba(0,0,0,0.03);
  
  display: flex;
  flex-direction: column;
  
  /* ★★★ 修改 1：底部留白从 40rpx 收紧到 16rpx ★★★ */
  /* 解决“距离底部太宽”的问题，让卡片跟得紧一点 */
  padding-bottom: 16rpx; 
}

/* 1.1 标题区域 */
.header-title-area {
  padding: 20rpx 40rpx 0 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1C1917;
  line-height: 1.2;
}

.subtitle {
  font-size: 22rpx;
  color: #A8A29E;
  font-weight: 500;
  margin-top: 8rpx;
  display: block;
}

/* 1.2 控制栏 (排序 + 筛选) */
.control-bar {
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  
  /* 排序和筛选之间的间距，保持适中 */
  gap: 24rpx; 
  
  margin-top: 30rpx;
}

/* 排序开关组 */
.sort-group {
  position: relative;
  display: flex;
  background: #E7E5E4;
  padding: 6rpx;
  border-radius: 20rpx;
  width: 300rpx;
  height: 64rpx;
  box-sizing: border-box;
  align-self: flex-start;
}

/* ... slider-bg 和 sort-btn 样式保持不变 ... */
/* (请保留之前的 slider-bg 和 sort-btn 代码) */
.slider-bg { position: absolute; top: 6rpx; left: 6rpx; bottom: 6rpx; width: calc(50% - 6rpx); background: #fff; border-radius: 16rpx; z-index: 1; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1); transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1); } .slider-bg.move-right { left: 50%; } .sort-btn { flex: 1; position: relative; z-index: 2; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 600; color: #78716C; transition: color 0.3s; } .sort-btn.active { color: #1C1917; font-weight: 700; }

/* 筛选滚动条 */
.filter-scroll {
  white-space: nowrap;
  display: flex;
  height: 84rpx; 
  align-items: flex-start;
  padding-top: 12rpx;
  width: 100vw;
  margin-left: -40rpx;
  margin-right: -40rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
  box-sizing: border-box; 
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  
  font-size: 22rpx;
  color: #57534E;
  background: #fff;
  border: 1rpx solid #E7E5E4;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.3s ease-in-out; 
}

.filter-chip.active {
  background: #1C1917;
  color: #fff;
  border-color: #1C1917;
  font-weight: 600;
}
  

/* ================================= */
/* 2. 列表区域 */
/* ================================= */
.list-container {
  padding: 30rpx 40rpx 80rpx 40rpx;
  /* 淡入动画 */
  animation: fadeIn 0.5s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  
  display: flex;
  gap: 24rpx;
  
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0,0,0,0.02);
  transition: transform 0.1s;
}

.card:active {
  transform: scale(0.98);
}

/* 左侧图片 */
.card-img-box {
  width: 200rpx;
  height: 200rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #F5F5F4;
  flex-shrink: 0;
  position: relative;
}

.card-img {
  width: 100%;
  height: 100%;
}

.img-date-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  
  /* 关键修改：加上这个，padding 就不会把盒子撑大导致偏右了 */
  box-sizing: border-box; 
  
  /* 颜色修改：使用深灰色 (rgba 50,50,50)，透明度降到 0.45，非常通透 */
  /* 之前的纯黑是 rgba(0,0,0,0.7) */
  background: linear-gradient(to top, rgba(50, 50, 50, 0.45) 0%, rgba(50, 50, 50, 0) 100%);
  
  /* 上下留白 */
  padding: 12rpx 0 6rpx 0; 
  
  display: flex;
  justify-content: center; /* 水平居中 */
  align-items: flex-end;
}

/* ★★★ 修改 2：日期文字微调 ★★★ */
.date-text {
  font-size: 18rpx; /* 稍微改小一号，更精致 */
  color: #fff;
  font-weight: 500; /* 不需要太粗 */
  opacity: 0.95;
  letter-spacing: 1rpx;
  
  /* 保留淡淡的文字阴影，保证在纯白图片上也能看清 */
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.2);
  
  font-feature-settings: "tnum"; 
  font-variant-numeric: tabular-nums;
  
  /* 确保文字本身不换行，居中显示 */
  text-align: center;
  width: 100%;
}

/* 图片占位符 */
.card-img-placeholder {
  width: 100%;
  height: 100%;
  background-color: #F5F5F4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 60rpx;
  opacity: 0.3;
  filter: grayscale(100%);
}

/* 右侧信息布局 */
.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.card-main {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* 眉标题 (国家) */
.eyebrow-country {
  font-size: 20rpx;
  font-weight: 800;
  color: #F97316; /* 橙色高亮 */
  letter-spacing: 1rpx;
  text-transform: uppercase;
  line-height: 1;
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.coffee-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1C1917;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.high-score-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #EF4444;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 12rpx;
  margin-left: 12rpx;
}

/* 次要信息区 */
.card-sub {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 10rpx;
}

.roaster-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.roaster-icon { font-size: 18rpx; color: #A8A29E; }

.roaster-name {
  font-size: 22rpx;
  color: #78716C;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 320rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.tags { display: flex; gap: 8rpx; }

.tag {
  font-size: 20rpx;
  color: #A8A29E;
  background: #F5F5F4;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.score-text {
  font-size: 36rpx;
  font-weight: 900;
  color: #1C1917;
  line-height: 1;
}

/* ================================= */
/* 3. Loading & 骨架屏 */
/* ================================= */

/* 底部加载文字/动画容器 */
.loading-footer {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.no-more-text {
  font-size: 22rpx;
  color: #D6D3D1;
  letter-spacing: 2rpx;
}

.loading-spinner {
  display: flex;
  gap: 8rpx;
}

.spinner-dot {
  width: 10rpx;
  height: 10rpx;
  background: #D6D3D1;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.spinner-dot:nth-child(1) { animation-delay: -0.32s; }
.spinner-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #A8A29E;
  font-size: 28rpx;
}

/* 高保真骨架屏 */
.skeleton {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  border: 1rpx solid #F5F5F4;
  box-sizing: border-box;
}

.sk-img {
  width: 200rpx; /* 与真实图片保持一致 */
  height: 200rpx;
  border-radius: 24rpx;
  background-color: #E5E7EB;
  flex-shrink: 0;
  animation: pulse 1.2s infinite ease-in-out;
}

.sk-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.sk-row {
  background-color: #E5E7EB;
  border-radius: 8rpx;
  animation: pulse 1.2s infinite ease-in-out;
}

.sk-eyebrow { width: 80rpx; height: 20rpx; margin-bottom: 12rpx; }
.sk-title { width: 90%; height: 32rpx; margin-bottom: auto; }
.sk-roaster { width: 60%; height: 24rpx; margin-bottom: 20rpx; }

.sk-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.sk-tag { width: 100rpx; height: 30rpx; background-color: #E5E7EB; border-radius: 8rpx; animation: pulse 1.2s infinite ease-in-out; }
.sk-score { width: 50rpx; height: 40rpx; background-color: #E5E7EB; border-radius: 8rpx; animation: pulse 1.2s infinite ease-in-out; }

@keyframes pulse {
  0% { opacity: 1; background-color: #E5E7EB; }
  50% { opacity: 0.4; background-color: #D1D5DB; }
  100% { opacity: 1; background-color: #E5E7EB; }
}

/* ================================= */
/* 4. 彩蛋蒙层 (强力修复版) */
/* ================================= */
.easter-egg-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.85);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.4s ease;
  backdrop-filter: blur(5px);
}

.easter-egg-modal.show {
  opacity: 1;
  visibility: visible;
}

.egg-content {
  width: 80%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  transform: scale(0.9);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  /* ★★★ 确保内容在撒花之上 ★★★ */
  z-index: 20; 
  position: relative;
}

.easter-egg-modal.show .egg-content { transform: scale(1); }

.egg-img {
  width: 100%;
  border-radius: 30rpx;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.3);
}

.egg-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* ================================= */
/* 5. 纯 CSS 撒花特效 (带默认值) */
/* ================================= */
.confetti-container {
  position: absolute;
  top: 50%; left: 50%;
  width: 0; height: 0;
  pointer-events: none;
  /* ★★★ 确保在背景之上，但在猫片之下 ★★★ */
  z-index: 10; 
}

.confetti {
  position: absolute;
  top: 0; left: 0;
  width: 12rpx; height: 12rpx;
  background-color: #FFD700;
  border-radius: 4rpx;
  opacity: 0; /* 默认隐藏 */
  
  /* ★★★ 保底设置：如果没有定义方向，就原地不动，防止报错 ★★★ */
  --tx: 0px; 
  --ty: -200rpx; 
  --c: #FFD700; 
}

/* 激活时开启动画 */
.confetti-container.active .confetti {
  animation: confetti-explode 1.5s ease-out forwards;
}

/* --- 下面是“暴力穷举”方向，确保每个粒子都有去处 --- */

/* 向四周炸开的 12 个基础方向 */
.confetti:nth-child(1) { --tx: -150rpx; --ty: -200rpx; --c: #EF4444; }
.confetti:nth-child(2) { --tx: 0rpx;    --ty: -250rpx; --c: #F59E0B; }
.confetti:nth-child(3) { --tx: 150rpx;  --ty: -200rpx; --c: #10B981; }
.confetti:nth-child(4) { --tx: 200rpx;  --ty: -50rpx;  --c: #3B82F6; }
.confetti:nth-child(5) { --tx: 150rpx;  --ty: 150rpx;  --c: #8B5CF6; }
.confetti:nth-child(6) { --tx: 0rpx;    --ty: 250rpx;  --c: #EC4899; }
.confetti:nth-child(7) { --tx: -150rpx; --ty: 150rpx;  --c: #EF4444; }
.confetti:nth-child(8) { --tx: -200rpx; --ty: -50rpx;  --c: #F59E0B; }

/* 增加随机感 */
.confetti:nth-child(3n)   { --tx: 100rpx; --ty: -280rpx; --c: #6366F1; }
.confetti:nth-child(3n+1) { --tx: -120rpx; --ty: -180rpx; --c: #F472B6; }
.confetti:nth-child(4n)   { --tx: 220rpx; --ty: 80rpx;   --c: #34D399; }
.confetti:nth-child(5n)   { --tx: -220rpx; --ty: 120rpx;  --c: #FBBF24; }
.confetti:nth-child(7n)   { --tx: -80rpx; --ty: -220rpx; --c: #60A5FA; }

/* 形状随机 */
.confetti:nth-child(even) { width: 10rpx; height: 10rpx; border-radius: 50%; }
.confetti:nth-child(odd)  { width: 16rpx; height: 8rpx; }

/* 应用颜色 */
.confetti { background-color: var(--c); }

@keyframes confetti-explode {
  0% {
    transform: translate(0, 0) scale(0);
    opacity: 1; /* 开始时可见 */
  }
  60% {
    opacity: 1;
  }
  100% {
    /* 使用 var 变量飞向指定位置，并旋转 */
    transform: translate(var(--tx), var(--ty)) rotate(720deg) scale(0.6);
    opacity: 0; /* 最后消失 */
  }
}

